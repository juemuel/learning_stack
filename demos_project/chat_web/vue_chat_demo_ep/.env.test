###  环境名
NODE_ENV="production" 
# 部署环境（测试环境和生产环境，NODE_ENV可以都设为production，只用于打包时的规则）

###  版本号
VUE_APP_VERSION = "20240826"

### 元化新版API - 接口地址，使用测试接口
VUE_APP_YH_API = "https://apitest.yhchmo.com/v2"

### 元化ChatAPI - 接口地址,使用测试接口
VUE_APP_YH_CHAT_API = "https://chat-api-test.yhchmo.com/v2"

### 环信配置APPKEY
VUE_APP_EM_APP_KEY = "1100240131157052#yh-his-prod"
### OSS - 接口地址
VUE_APP_YH_OSS_URL = 'https://oss.yhchmo.com'
VUE_APP_YH_OSS_ROOT_DIRECTORY = "/demo"
###  打包名
VUE_APP_DIR_NAME="build_dev"
